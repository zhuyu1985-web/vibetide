# 复制为 .env.deploy 后填写，供 docker compose --env-file .env.deploy 使用
# 勿将 .env.deploy 提交到版本库

# ── Supabase / Postgres（四件套）────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@your-supabase-db-host:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-kong-or-api.example.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── 应用必需 ───────────────────────────────────
# ≥32 字符：node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SESSION_SECRET=

# ── 可选 ───────────────────────────────────────
APP_PORT=3000
SUPABASE_STORAGE_BUCKET_REPORTS=research-reports

# AI / 搜索等（按需）
# OPENAI_API_KEY=
# OPENAI_API_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
