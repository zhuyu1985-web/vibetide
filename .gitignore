# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env*.example

# vercel
.vercel

# db backups (本地全量/增量 SQL dump,体积大,不入 git)
# scripts/db-export-full.sh 自动写到 backups/
backups/

# typescript
*.tsbuildinfo
next-env.d.ts
.worktrees/
.claude/worktrees/
.superpowers/

# Playwright MCP 调试产物
.playwright-mcp/

# 数据库 dump / 备份文件（不入仓）
*.sql
!supabase/migrations/*.sql

# tikhub 探针脚本输出(含真实账号响应,可能包含个人信息)
scripts/tikhub-probe-output/

# 工具/IDE 状态目录
.agents/
.codex/

# 大体积数据/演示文档(476MB json + 51MB presentations 等,不入仓)
docs/data.xlsx
docs/test-site.xlsx
docs/json/
docs/presentations/
